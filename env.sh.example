#!/usr/bin/env bash
# ============================================================================
# MailPilot — Environment Configuration
#
# Copy this file:   cp env.sh.example env.sh
# Then edit env.sh with your real values.
#
# All scripts (setup.sh, start.sh, deploy.sh) will source env.sh
# automatically. You can also source it manually:
#   source env.sh
# ============================================================================

# ── OpenAI ─────────────────────────────────────────────────────────────────
# Your OpenAI API key. Get one at: https://platform.openai.com/api-keys
# Format: sk-proj-... or sk-...
export OPENAI_API_KEY="<paste-your-openai-api-key-here>"

# Model used for normal emails. Options: gpt-4o-mini, gpt-4o, gpt-4-turbo
export DEFAULT_MODEL="gpt-4o-mini"

# Model used when escalation is triggered (legal, immigration, tuition keywords)
export ESCALATION_MODEL="gpt-4o"

# ── Internal API Auth ──────────────────────────────────────────────────────
# Shared secret between the Outlook add-in and the backend.
# The frontend sends this as the X-API-Key header; the backend verifies it.
#
# Generate a strong random token:
#   openssl rand -hex 32
#   python3 -c "import secrets; print(secrets.token_hex(32))"
export MAILPILOT_API_TOKEN="<generate-a-random-token-and-paste-here>"

# ── CORS ───────────────────────────────────────────────────────────────────
# Frontend origin that the backend allows.
#   Dev (npm run dev)  : https://localhost:3000
#   Docker (nginx)     : https://localhost
#   Production         : https://your-domain.com
export MAILPILOT_ALLOWED_ORIGIN="https://localhost:3000"

# ── Database ───────────────────────────────────────────────────────────────
# Async SQLite connection string. The file is auto-created on first run.
#   Dev    : sqlite+aiosqlite:///./mailpilot.db
#   Docker : sqlite+aiosqlite:///./data/mailpilot.db  (persistent volume)
export DATABASE_URL="sqlite+aiosqlite:///./mailpilot.db"

# ── Processing Limits (optional, defaults are fine) ────────────────────────
# export MAX_BODY_LENGTH=5000
# export MAX_CATEGORIES_PER_EMAIL=3
# export RATE_LIMIT_PER_MINUTE=30
